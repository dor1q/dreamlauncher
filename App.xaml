<Application x:Class="DreamLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#0B1020" />
        <SolidColorBrush x:Key="PanelBrush" Color="#121A2D" />
        <SolidColorBrush x:Key="PanelStrongBrush" Color="#18233A" />
        <SolidColorBrush x:Key="BorderBrushColor" Color="#2B3853" />
        <SolidColorBrush x:Key="TextBrush" Color="#EDF2FF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#97A4BB" />
        <SolidColorBrush x:Key="AccentBrush" Color="#57C78B" />
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#33A56A" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF6B6B" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource WindowBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#1A2438" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource BaseButton}" />

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource AccentStrongBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
            <Setter Property="Foreground" Value="#07130D" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#0D1425" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushColor}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#0D1425" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushColor}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
    </Application.Resources>
</Application>
