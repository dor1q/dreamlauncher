<Window x:Class="DreamLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DreamLauncher.Models"
        Title="Dream Launcher"
        Width="840"
        Height="640"
        MinWidth="780"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#080D0F"
        BorderThickness="0"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Loaded="Window_Loaded">
    <Border Background="{StaticResource ShellBrush}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="0" Margin="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="178" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,1,0" CornerRadius="6,0,0,6">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="76" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DREAM" FontSize="26" FontWeight="Black" />
                            <TextBlock Text="v0.1.0" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="5,11,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="HeaderOnlineText" Text="500 Players Online" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" FontSize="12" Margin="1,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <Button x:Name="HomeNavButton" Content="HOME" Tag="Home" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" />
                        <Button x:Name="LeaderboardNavButton" Content="LEADERBOARDS" Tag="Leaderboard" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" />
                        <Button x:Name="LibraryNavButton" Content="LIBRARY" Tag="Library" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" />
                        <Button x:Name="DownloadsNavButton" Content="DOWNLOADS" Tag="Downloads" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" />
                        <Button x:Name="StatusNavButton" Content="STATUS" Tag="Status" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Button Content="DONATE" Style="{StaticResource DonateButtonStyle}" Click="Donate_Click" />
                        <Button x:Name="SettingsNavButton" Content="SETTINGS" Tag="Settings" Style="{StaticResource NavButtonStyle}" Margin="0,8,0,0" Click="Nav_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="74" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="56" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,0,1" MouseLeftButtonDown="WindowChrome_MouseLeftButtonDown">
                    <Grid Margin="18,10,14,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderUserText" Text="#00000 Guest" FontSize="17" FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border x:Name="LaunchStatePill" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="12" Padding="9,4" Margin="0,0,8,0">
                                    <TextBlock x:Name="LaunchStateText" Text="Launch: idle" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                </Border>
                                <TextBlock x:Name="SelectedBuildText" Text="No build selected" Foreground="{StaticResource MutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="360" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <TextBlock Text="Ultimate Donator" Foreground="{StaticResource YellowBrush}" FontSize="11" FontWeight="Bold" Margin="0,7,18,0" />
                            <Button Content="-" Width="28" Height="24" Padding="0" Background="Transparent" BorderBrush="Transparent" Click="Minimize_Click" />
                            <Button Content="X" Width="28" Height="24" Padding="0" Background="Transparent" BorderBrush="Transparent" Click="CloseWindow_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="18,12,18,0">
                    <Grid x:Name="HomePage">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56" />
                            <RowDefinition Height="92" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="82" />
                        </Grid.RowDefinitions>

                        <Border Background="#111411" CornerRadius="5" Padding="14,9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="46" Height="46">
                                    <Ellipse x:Name="HomeAvatarEllipse">
                                        <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#22E1FF" Offset="0" />
                                            <GradientStop Color="#FF4C4C" Offset="1" />
                                        </LinearGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock x:Name="HomeAvatarFallbackText" Text="D" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Welcome" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
                                    <TextBlock x:Name="WelcomeNameText" Text="Guest" FontSize="20" FontWeight="Black" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" CornerRadius="5" Margin="0,8,0,0" Padding="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4E58FF" Offset="0" />
                                    <GradientStop Color="#2F92FF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="HomeStatusTitleText" Text="Ready to check services" FontSize="17" FontWeight="Black" />
                                <TextBlock x:Name="HomeStatusSubtitleText" Grid.Row="1" Text="Start the backend and press Check on the Status page." Foreground="#DCE7FF" FontSize="12" FontWeight="SemiBold" />
                                <Grid Grid.Row="2" VerticalAlignment="Bottom">
                                    <Border Height="22" Background="#3157B8" CornerRadius="3" />
                                    <ProgressBar Height="5" Margin="3,14,3,3" Value="68" Minimum="0" Maximum="100" Foreground="#00E3C0" Background="#22569F" BorderThickness="0" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" CornerRadius="5" Margin="0,8,0,0" ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#C800F5" Offset="0" />
                                    <GradientStop Color="#6332FF" Offset="0.55" />
                                    <GradientStop Color="#161B1A" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <TextBlock Text="DREAM" FontSize="112" FontWeight="Black" Foreground="#22FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0" />
                                <StackPanel VerticalAlignment="Bottom" Margin="14,0,14,28">
                                    <TextBlock Text="TEAM MODES ARE HERE" FontSize="20" FontWeight="Black" />
                                    <TextBlock Text="Squad up, check service health, pick a local build, and launch when your account is ready." Foreground="#DAD6FF" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border CornerRadius="5" Padding="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#80B500" Offset="0" />
                                        <GradientStop Color="#466C00" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="SEASON PROGRESS" Foreground="#D5FF9B" FontSize="13" FontWeight="Black" />
                                    <TextBlock x:Name="HomeBuildText" Text="No build selected" FontSize="20" FontWeight="Black" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" CornerRadius="5" Padding="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#EF4DA6" Offset="0" />
                                        <GradientStop Color="#5636E8" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="LOCAL LIBRARY" Foreground="#FFE3F3" FontSize="13" FontWeight="Black" />
                                    <TextBlock x:Name="BuildCountText" Text="0 builds installed" FontSize="20" FontWeight="Black" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid x:Name="LeaderboardPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="54" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="LEADERBOARDS" FontSize="22" FontWeight="Black" />
                            <TextBlock Text="Ranked by score. Wins are 10 points, eliminations are 1 point." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,4,0,0">
                            <Grid Height="40"><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBlock Text="#1" Foreground="{StaticResource YellowBrush}" FontWeight="Black" FontSize="17" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="synikle" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="4735 ELIMS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="664 WINS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="11375" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/></Grid>
                            <Grid Height="40"><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBlock Text="#2" FontWeight="Black" FontSize="17" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="Zetron" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="5147 ELIMS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="575 WINS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="10897" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/></Grid>
                            <Grid Height="40"><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBlock Text="#3" Foreground="#FF4FB0" FontWeight="Black" FontSize="17" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="ryzenn24" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="4475 ELIMS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="418 WINS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="8655" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/></Grid>
                            <Grid Height="40"><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBlock Text="#4" Foreground="{StaticResource AccentBrush}" FontWeight="Black" FontSize="17" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="Slope!" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="2032 ELIMS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="510 WINS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="7132" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/></Grid>
                            <Grid Height="40"><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBlock Text="#5" Foreground="{StaticResource AccentBrush}" FontWeight="Black" FontSize="17" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="Glow" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="3009 ELIMS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="392 WINS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="6929" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/></Grid>
                            <Grid Height="40"><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBlock Text="#6" Foreground="{StaticResource AccentBrush}" FontWeight="Black" FontSize="17" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="daveyyyfx" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="3973 ELIMS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="241 WINS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="6383" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/></Grid>
                            <Grid Height="40"><Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="*"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions><TextBlock Text="#7" Foreground="{StaticResource AccentBrush}" FontWeight="Black" FontSize="17" VerticalAlignment="Center"/><TextBlock Grid.Column="1" Text="sznvfx" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="2621 ELIMS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="3" Text="376 WINS" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/><TextBlock Grid.Column="4" Text="6381" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" VerticalAlignment="Center"/></Grid>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="LibraryPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="156" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="66" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Library" FontSize="22" FontWeight="Black" />
                                <TextBlock Text="Select a local build, inspect its executable, then launch when account and backend are ready." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <Button Content="Add exe" Click="AddBuildExecutable_Click" />
                                <Button Content="Add folder" Margin="8,0,0,0" Click="AddBuildFolder_Click" />
                                <Button Content="Remove" Margin="8,0,0,0" Click="RemoveSelectedBuild_Click" />
                                <Button Content="Open folder" Margin="8,0,0,0" Click="OpenBuildFolder_Click" />
                                <Button Content="Open manifest" Margin="8,0,0,0" Click="OpenManifest_Click" />
                            </StackPanel>
                            <Border Grid.Row="2" Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Padding="10,7" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="LibrarySelectedBuildNameText" Text="Selected build: none" FontWeight="Black" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="LibrarySelectedExecutableText" Grid.Row="1" Text="Executable: no build selected" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="LibrarySelectedPathText" Grid.Row="2" Text="Folder: no build selected" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </Grid>

                        <ListBox x:Name="BuildsListBox" Grid.Row="1" SelectionChanged="BuildsListBox_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,8,8" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                <Border x:Name="ItemChrome" Background="Transparent" BorderBrush="Transparent" BorderThickness="2" CornerRadius="7" Padding="2">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="#1A211C" />
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#344239" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="#142819" />
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:BuildDefinition}">
                                    <Border Width="184" Height="126" CornerRadius="5" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" ClipToBounds="True">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="42" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#7A1CC7" Offset="0" />
                                                        <GradientStop Color="#101412" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding ExecutableFileName}" FontSize="11" FontWeight="Black" Foreground="#DDF7E4" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,10,0" TextTrimming="CharacterEllipsis" />
                                            </Border>
                                            <Border Grid.Row="1" Background="#CC111411" Padding="8,6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Black" FontSize="14" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Path}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding ResolvedExecutable}" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Grid x:Name="DownloadsPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="76" />
                            <RowDefinition Height="104" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Downloads" FontSize="22" FontWeight="Black" />
                                <TextBlock Text="Manage local builds, verify required files, and prepare installs from the content directory." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <Button Content="Add exe" Click="AddBuildExecutable_Click" />
                                <Button Content="Add folder" Margin="8,0,0,0" Click="AddBuildFolder_Click" />
                                <Button Content="Verify selected" Margin="8,0,0,0" Click="VerifySelectedBuild_Click" />
                                <Button Content="Open folder" Margin="8,0,0,0" Click="OpenBuildFolder_Click" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="DownloadsSelectedBuildText" Text="No build selected" FontSize="17" FontWeight="Black" />
                                <TextBlock x:Name="DownloadsContentDirectoryText" Grid.Row="1" Text="Content directory is not configured" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <Grid Grid.Row="2" VerticalAlignment="Bottom">
                                    <Border Height="22" Background="#202621" CornerRadius="3" />
                                    <ProgressBar x:Name="DownloadProgressBar" Height="5" Margin="3,14,3,3" Value="0" Minimum="0" Maximum="100" Foreground="{StaticResource AccentBrush}" Background="#2A302D" BorderThickness="0" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Margin="10,8">
                                    <TextBlock Text="Verify Results" FontWeight="Black" VerticalAlignment="Center" />
                                    <TextBlock x:Name="DownloadStatusText" Text="Run Verify selected to inspect the current build." Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="360" />
                                </Grid>
                                <ListBox x:Name="VerificationResultsListBox" Grid.Row="1" Margin="10,0,10,10">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:BuildVerificationItem}">
                                            <Border BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,0,1" Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="90" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Details}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="2" Text="{Binding State}" FontWeight="Black" HorizontalAlignment="Right" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="StatusPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="86" />
                            <RowDefinition Height="98" />
                            <RowDefinition Height="140" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Status" FontSize="22" FontWeight="Black" />
                                <TextBlock Text="Check backend, database, XMPP, matchmaker, and game server reachability." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Content="Check" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="92" Click="CheckStatus_Click" />
                        </Grid>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="BackendStatusPill" Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="BACKEND" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                    <TextBlock x:Name="BackendStatusText" Text="Backend: not checked" FontSize="15" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <Border x:Name="GameServerStatusPill" Grid.Column="2" Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="GAME SERVER" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                    <TextBlock x:Name="GameServerStatusText" Text="Game server: not checked" FontSize="15" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Grid.Row="2" Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Backend Services" FontWeight="Black" Margin="10,8,10,0" />
                                <ListBox x:Name="BackendServicesListBox" Grid.Row="1" Margin="10,0,10,10">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:LauncherServiceStatus}">
                                            <Border Width="146" Height="78" Background="#151817" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Padding="9" Margin="0,0,8,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" FontWeight="Black" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding State}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Details}" Foreground="{StaticResource MutedBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Margin="10,8">
                                    <TextBlock Text="Runtime Logs" FontWeight="Black" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Export report" Height="26" MinHeight="26" Click="ExportReport_Click" />
                                        <Button Content="Clear" Height="26" MinHeight="26" Margin="8,0,0,0" Click="ClearLogs_Click" />
                                    </StackPanel>
                                </Grid>
                                <ListBox x:Name="LogListBox" Grid.Row="1" Margin="10,0,10,10" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="SettingsPage" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Settings &amp; Options" FontSize="22" FontWeight="Black" />
                                <TextBlock Text="Customize your launcher experience here." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,10" />

                                <TextBlock Text="Network" Foreground="{StaticResource DimBrush}" FontWeight="Bold" />
                                <Border Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,4,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="94" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Backend URL" FontWeight="Bold" />
                                            <TextBox x:Name="BackendUrlTextBox" Margin="0,5,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Game server host" FontWeight="Bold" />
                                            <TextBox x:Name="GameServerHostTextBox" Margin="0,5,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Margin="10,0,0,0">
                                            <TextBlock Text="Port" FontWeight="Bold" />
                                            <TextBox x:Name="GameServerPortTextBox" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <TextBlock Text="Discord" Foreground="{StaticResource DimBrush}" FontWeight="Bold" />
                                <Border Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,4,0,10">
                                    <StackPanel>
                                        <Border x:Name="DiscordAuthPill" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="12" Padding="9,5" Margin="0,0,0,10">
                                            <TextBlock x:Name="DiscordAuthTextBlock" Text="Discord: signed out" Foreground="{StaticResource MutedBrush}" />
                                        </Border>
                                        <TextBlock Text="Discord login is handled by the backend. Set OAuth Client ID and Secret in backend .env." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        <TextBlock Text="Callback port" FontWeight="Bold" />
                                        <TextBox x:Name="DiscordRedirectPortTextBox" Margin="0,5,0,10" Width="130" HorizontalAlignment="Left" />
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="LoginDiscordButton" Content="Login with Discord" Style="{StaticResource PrimaryButton}" Width="170" Click="LoginDiscord_Click" />
                                            <Button x:Name="LogoutDiscordButton" Content="Logout" Margin="8,0,0,0" Width="90" Click="LogoutDiscord_Click" IsEnabled="False" />
                                            <Button Content="Save settings" Margin="8,0,0,0" Width="124" Click="SaveSettings_Click" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Local files" Foreground="{StaticResource DimBrush}" FontWeight="Bold" />
                                <Border Background="#101311" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,4,0,0">
                                    <StackPanel>
                                        <CheckBox x:Name="AutoDownloadCheckBox" Content="Auto download new content patches" />
                                        <CheckBox x:Name="DetailedDownloadsCheckBox" Content="Show detailed download and verify output" />
                                        <TextBlock Text="CONTENT DIRECTORY" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                        <Grid Margin="0,2,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="86" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ContentDirectoryTextBox" />
                                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" Click="BrowseContentDirectory_Click" />
                                        </Grid>
                                        <TextBlock Text="BUILD MANIFEST" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                        <TextBlock x:Name="ManifestPathTextBlock" TextTrimming="CharacterEllipsis" Margin="0,2,0,8" />
                                        <TextBlock Text="SETTINGS FILE" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                        <TextBlock x:Name="SettingsPathTextBlock" TextTrimming="CharacterEllipsis" Margin="0,2,0,8" />
                                        <TextBlock Text="SESSION FILE" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Black" />
                                        <TextBlock x:Name="SessionPathTextBlock" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <Border Grid.Row="2" Padding="18,8,18,12">
                    <Button x:Name="LaunchButton" Content="LAUNCH DREAM" Style="{StaticResource PrimaryButton}" Height="38" Click="Launch_Click" IsEnabled="False" />
                </Border>
            </Grid>

            <Grid x:Name="AuthGateOverlay" Grid.ColumnSpan="2" Panel.ZIndex="50" Visibility="Collapsed" Background="#D9080D0F">
                <Border Width="360" Background="#151817" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="6" Padding="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="DREAM" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="Black" />
                        <TextBlock Text="Login Required" FontSize="28" FontWeight="Black" Margin="0,2,0,4" />
                        <TextBlock Text="Sign in with Discord before using the launcher." Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,14" />

                        <Border x:Name="AuthGateStatusPill" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="12" Padding="9,5" Margin="0,0,0,14">
                            <TextBlock x:Name="AuthGateStatusTextBlock" Text="Discord: signed out" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                        </Border>

                        <Button x:Name="AuthGateLoginButton" Content="Login with Discord" Style="{StaticResource PrimaryButton}" Height="38" Click="AuthGateLogin_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
