<Window x:Class="DreamLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DreamLauncher.Models"
        Title="Dream Launcher"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0E1526" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DREAM" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
                    <TextBlock Text="Launcher" FontSize="34" FontWeight="Bold" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="BackendStatusPill" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="16" Padding="12,8" Margin="0,0,10,0" Width="240">
                        <TextBlock x:Name="BackendStatusText" Text="Backend: not checked" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border x:Name="GameServerStatusPill" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="16" Padding="12,8" Width="240">
                        <TextBlock x:Name="GameServerStatusText" Text="Game server: not checked" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" MinWidth="520" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.85*" MinWidth="320" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="350" />
                <RowDefinition Height="16" />
                <RowDefinition Height="190" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="72" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,0,1" Padding="18">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="LOCAL BUILDS" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Text="Choose build" FontSize="20" FontWeight="SemiBold" />
                            </StackPanel>
                            <Button Content="Refresh" HorizontalAlignment="Right" Click="RefreshBuilds_Click" />
                        </Grid>
                    </Border>

                    <ListBox x:Name="BuildsListBox" Grid.Row="1" Margin="16" SelectionChanged="BuildsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:BuildDefinition}">
                                <Border BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10" Background="#10182A">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Path}" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Executable}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="12" Padding="8,4" VerticalAlignment="Top" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Id}" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,1,0,0" Padding="16">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="LaunchButton" Content="Launch" Style="{StaticResource PrimaryButton}" Width="140" Click="Launch_Click" IsEnabled="False" />
                            <Button Content="Open manifest" Margin="10,0,0,0" Click="OpenManifest_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,0,1" Padding="18">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="ACCOUNT" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Text="Discord login" FontSize="20" FontWeight="SemiBold" />
                            </StackPanel>
                            <Button Content="Check" HorizontalAlignment="Right" Click="CheckStatus_Click" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <Border x:Name="DiscordAuthPill" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="16" Padding="12,8" Margin="0,0,0,14">
                                <TextBlock x:Name="DiscordAuthTextBlock" Text="Discord: signed out" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                            </Border>

                            <TextBlock Text="Discord client id" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBox x:Name="DiscordClientIdTextBox" Margin="0,7,0,14" />

                            <TextBlock Text="Discord client secret" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <PasswordBox x:Name="DiscordClientSecretPasswordBox" Margin="0,7,0,14" />

                            <TextBlock Text="Callback port" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBox x:Name="DiscordRedirectPortTextBox" Margin="0,7,0,14" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Button x:Name="LoginDiscordButton" Content="Login with Discord" Style="{StaticResource PrimaryButton}" Width="170" Click="LoginDiscord_Click" />
                                <Button x:Name="LogoutDiscordButton" Content="Logout" Margin="10,0,0,0" Width="90" Click="LogoutDiscord_Click" IsEnabled="False" />
                            </StackPanel>

                            <Border BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,1,0,0" Margin="0,0,0,16" />

                            <TextBlock Text="Backend URL" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                            <TextBox x:Name="BackendUrlTextBox" Margin="0,7,0,14" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Game server host" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                                    <TextBox x:Name="GameServerHostTextBox" Margin="0,7,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Port" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                                    <TextBox x:Name="GameServerPortTextBox" Margin="0,7,0,0" />
                                </StackPanel>
                            </Grid>

                            <Button Content="Save settings" Style="{StaticResource PrimaryButton}" Margin="0,16,0,0" Click="SaveSettings_Click" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="16">
                        <TextBlock Text="BUILD MANIFEST" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
                        <TextBlock x:Name="ManifestPathTextBlock" TextTrimming="CharacterEllipsis" Margin="0,5,0,12" />
                        <TextBlock Text="SETTINGS FILE" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
                        <TextBlock x:Name="SettingsPathTextBlock" TextTrimming="CharacterEllipsis" Margin="0,5,0,12" />
                        <TextBlock Text="SESSION FILE" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
                        <TextBlock x:Name="SessionPathTextBlock" TextTrimming="CharacterEllipsis" Margin="0,5,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,0,1" Padding="18,12">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="RUNTIME" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Text="Logs" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <Button Content="Clear" HorizontalAlignment="Right" Click="ClearLogs_Click" />
                        </Grid>
                    </Border>

                    <ListBox x:Name="LogListBox" Grid.Row="1" Margin="14" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
